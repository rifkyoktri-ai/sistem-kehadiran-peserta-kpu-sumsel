# =============================================================================
# ENVIRONMENT VARIABLES — Sistem Registrasi KPU Provinsi Sumatera Selatan
# =============================================================================
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan server.
# =============================================================================

PORT=3001
NODE_ENV=development

# Password akses — WAJIB diisi sebelum deploy!
PASSWORD_PETUGAS=<ganti_dengan_password_petugas>
PASSWORD_ADMIN=<ganti_dengan_password_admin>

# CORS — daftar domain yang diizinkan (pisahkan dengan koma)
# Contoh: https://registrasi.kpu-sumsel.go.id,http://localhost:5173
# Kosongkan untuk mengizinkan hanya localhost saat development
CORS_ORIGINS=

# JWT — Secret key untuk menandatangani token autentikasi
# Gunakan nilai acak panjang (min 32 karakter) untuk produksi!
JWT_SECRET=ganti_dengan_jwt_secret_acak_panjang

# Masa berlaku token JWT (default: 24h)
JWT_EXPIRY=24h

# =============================================================================
# EMAIL (Gmail SMTP) — untuk kirim email konfirmasi otomatis ke peserta
# =============================================================================
# Jika dikosongkan, fitur email otomatis nonaktif (server tetap berjalan normal).
#
# Cara membuat App Password:
# 1. Aktifkan 2-Step Verification di akun Google: https://myaccount.google.com/security
# 2. Buka https://myaccount.google.com/apppasswords
# 3. Buat App Password baru (pilih App: Mail, Device: Other) → salin 16 digit yang muncul
# 4. Jangan gunakan password akun Gmail biasa — WAJIB App Password!
GMAIL_USER=<alamat_gmail_pengirim@gmail.com>
GMAIL_APP_PASSWORD=<16_digit_app_password>
